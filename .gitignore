# Ignore files generated by the build process
build/
dist/
*.egg-info/

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak
*.log

# PowerShell execution logs
*.ps1.log

# Any local testing or scratch files
scratch/
test-output/
temp/
tmp/

# =============================================================================
# SECRETS - NEVER COMMIT
# =============================================================================
# Environment files with actual secrets
.env
.env.local
.env.*.local
*.env

# Secret files
secrets.json
secrets.yaml
secrets.yml
secrets.toml

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.pkcs12

# Allow schema and example files (safe for AI to read)
!.env.schema
!.env.example
